# Agentic AEO - Multi-Agent System Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# REQUIRED: Claude API Configuration
# ============================================================================

# Anthropic API key (required for all agent operations)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================================================
# OPTIONAL: Cost Optimization Settings
# ============================================================================

# Enable prompt caching (90% cost savings, requires Claude Max Pro)
# Values: true, false
# Default: true
ENABLE_PROMPT_CACHING=true

# Enable extended context (200K tokens instead of 8K)
# Values: true, false
# Default: true
ENABLE_EXTENDED_CONTEXT=true

# Enable request batching (combine multiple agent calls)
# Values: true, false
# Default: true
ENABLE_REQUEST_BATCHING=true

# ============================================================================
# OPTIONAL: Agent Configuration
# ============================================================================

# Maximum parallel agents (orchestrator spawns this many simultaneously)
# Range: 1-6
# Default: 6
MAX_PARALLEL_AGENTS=6

# Agent timeout in seconds
# Default: 300 (5 minutes)
AGENT_TIMEOUT_SECONDS=300

# Agent retry attempts on failure
# Default: 3
AGENT_MAX_RETRIES=3

# Agent retry delay in seconds (exponential backoff)
# Default: 2
AGENT_RETRY_DELAY_SECONDS=2

# ============================================================================
# OPTIONAL: Data Persistence
# ============================================================================

# Local data directory for campaign storage
# Default: .aeo-agent-data
DATA_DIR=.aeo-agent-data

# Enable data compression for stored JSON files
# Values: true, false
# Default: false
ENABLE_DATA_COMPRESSION=false

# ============================================================================
# OPTIONAL: Logging Configuration
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Default: INFO
LOG_LEVEL=INFO

# Log format (json, text)
# Default: json
LOG_FORMAT=json

# Log file path (empty = stdout only)
# Default: empty
LOG_FILE=

# Enable verbose agent communication logs
# Values: true, false
# Default: false
VERBOSE_AGENT_LOGS=false

# ============================================================================
# OPTIONAL: API Server Configuration
# ============================================================================

# FastAPI server host
# Default: 0.0.0.0
API_HOST=0.0.0.0

# FastAPI server port
# Default: 8000
API_PORT=8000

# Enable API debug mode
# Values: true, false
# Default: false
API_DEBUG=false

# API rate limiting (requests per minute)
# Default: 60
API_RATE_LIMIT=60

# CORS allowed origins (comma-separated list)
# Security: NEVER use "*" in production - specify explicit origins
# Default: http://localhost:3000,http://localhost:8080
# Production example: https://yourdomain.com,https://app.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ============================================================================
# OPTIONAL: LLM Provider Configuration (for Citation Tracker)
# ============================================================================

# OpenAI API key (optional - for ChatGPT citation tracking)
OPENAI_API_KEY=

# Google API key (optional - for Gemini citation tracking)
GOOGLE_API_KEY=

# Mistral API key (optional - for Mistral citation tracking)
MISTRAL_API_KEY=

# Perplexity API key (optional - for Perplexity citation tracking)
PERPLEXITY_API_KEY=

# ============================================================================
# OPTIONAL: Advanced Settings
# ============================================================================

# Enable privacy mode (disable telemetry and external requests)
# Values: true, false
# Default: false
PRIVACY_MODE=false

# Campaign retention days (auto-delete old campaigns)
# Default: 90 (0 = never delete)
CAMPAIGN_RETENTION_DAYS=90

# Enable experimental features
# Values: true, false
# Default: false
ENABLE_EXPERIMENTAL_FEATURES=false
